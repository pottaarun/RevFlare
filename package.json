{
  "name": "revflare",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:create": "wrangler d1 create revflare-db",
    "db:init": "wrangler d1 execute revflare-db --local --file=schema.sql",
    "db:init:remote": "wrangler d1 execute revflare-db --remote --file=schema.sql",
    "seed": "node seed.mjs"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^1.0.6",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.81.0",
    "xlsx": "^0.18.5"
  }
}
